{
  "appId": "com.peopledesk.app",
  "appName": "PeopleDesk",
  "webDir": "dist",
  "server": {
    "androidScheme": "http",
    "cleartext": true,
    "allowNavigation": [
      "192.168.1.121"
    ]
  },
  "plugins": {
    "BackgroundRunner": {
      "label": "com.peopledesk.app.runner",
      "src": "runner.js",
      "event": "dailyCallLogSync",
      "repeat": true,
      "interval": 15,
      "autoStart": true
    }
  }
}